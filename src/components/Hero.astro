---
interface Props {
  badge?: string;
  title?: string;
  titleHighlight?: string;
  subtitle?: string;
  stat1Number?: string;
  stat1Label?: string;
  stat2Number?: string;
  stat2Label?: string;
  stat3Number?: string;
  stat3Label?: string;
}
const {
  badge = '🔥 Ofertas Exclusivas',
  title = 'Suplementos e emagrecedores que',
  titleHighlight = 'realmente funcionam',
  subtitle = 'Selecionamos os melhores suplementos, termogênicos e emagrecedores do mercado com os melhores preços. Aproveite nossas ofertas e compre com segurança.',
  stat1Number = '+50mil',
  stat1Label = 'Clientes satisfeitos',
  stat2Number = '100%',
  stat2Label = 'Garantia de entrega',
  stat3Number = '4.9★',
  stat3Label = 'Avaliação média',
} = Astro.props;
---
<section class="hero">
  <div class="container">
    <div class="badge">{badge}</div>
    <h1>{title} <span class="highlight">{titleHighlight}</span></h1>
    <p>{subtitle}</p>
    <div class="stats">
      <div class="stat">
        <strong>{stat1Number}</strong>
        <span>{stat1Label}</span>
      </div>
      <div class="divider"></div>
      <div class="stat">
        <strong>{stat2Number}</strong>
        <span>{stat2Label}</span>
      </div>
      <div class="divider"></div>
      <div class="stat">
        <strong>{stat3Number}</strong>
        <span>{stat3Label}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #0f0f0f 0%, #0a1505 50%, #0f0f0f 100%);
    padding: 4rem 0 3rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(113, 192, 55,0.15) 0%, transparent 70%);
  }
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }
  .badge {
    display: inline-block;
    background: rgba(113, 192, 55,0.15);
    border: 1px solid rgba(113, 192, 55,0.4);
    color: var(--primary);
    padding: 0.35rem 1rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    letter-spacing: 0.5px;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 1rem;
    letter-spacing: -1px;
  }
  .highlight {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  p {
    font-size: 1.1rem;
    color: var(--gray-400);
    max-width: 540px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .stat strong {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--white);
  }
  .stat span {
    font-size: 0.8rem;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .divider {
    width: 1px;
    height: 40px;
    background: var(--gray-700);
  }
  @media (max-width: 500px) {
    .divider { display: none; }
    .stats { gap: 1.5rem; }
  }
</style>
