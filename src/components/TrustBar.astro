---
interface TrustItem { icon: string; title: string; subtitle: string; }
interface Props { items?: TrustItem[]; }
const {
  items = [
    { icon: '🔒', title: 'Compra Segura', subtitle: 'Ambiente 100% protegido' },
    { icon: '📦', title: 'Entrega Garantida', subtitle: 'Rastreamento em tempo real' },
    { icon: '💳', title: 'Parcelamento', subtitle: 'Em até 12x sem juros' },
    { icon: '↩️', title: '30 dias de garantia', subtitle: 'Devolução sem perguntas' },
  ],
} = Astro.props;
---
<section class="trust">
  <div class="container">
    {items.map((item) => (
      <div class="trust-item">
        <span class="icon">{item.icon}</span>
        <div>
          <strong>{item.title}</strong>
          <span>{item.subtitle}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .trust {
    background: linear-gradient(135deg, #111, #1a1a1a);
    border-top: 1px solid #2a2a2a;
    border-bottom: 1px solid #2a2a2a;
    padding: 1.75rem 0;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .icon { font-size: 1.75rem; }
  .trust-item div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  strong {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
  }
  span {
    font-size: 0.75rem;
    color: var(--gray-400);
  }
</style>
