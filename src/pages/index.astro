---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import ProductCarousel from '../components/ProductCarousel.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
import headerData from '../data/header.json';
import heroData from '../data/hero.json';
import trustbarData from '../data/trustbar.json';
import testimonialsData from '../data/testimonials.json';
import footerData from '../data/footer.json';

const entries = await getCollection('products');
const products = entries.map((entry) => ({ ...entry.data, slug: entry.id }));
---

<Layout title="FS FitLife — Suplementos e Emagrecedores">
  <Header tagline={headerData.tagline} />
  <main>
    <Hero {...heroData} />
    <ImageCarousel />
    <TrustBar items={trustbarData.items} />
    <ProductCarousel products={products} />
    <Testimonials {...testimonialsData} />
  </main>
  <Footer {...footerData} />
</Layout>
